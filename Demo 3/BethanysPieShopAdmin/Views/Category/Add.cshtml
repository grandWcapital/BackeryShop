@model Category

<h2>Create a new category</h2>
<hr/>
<form method="post" asp-controller="Category" asp-action="Add">

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-label" />
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-label" />
    </div>
    <div class="mb-3">
        <label asp-for="DateAdded" class="form-label"></label>
        <input asp-for="DateAdded" class="form-label" />
    </div>
    <input type ="submit" value="Add category" class=" = btn btn-primary"
</form>
<div>

    <a asp-controller="Category" asp-action="Index">Back to overview</a>
</div>